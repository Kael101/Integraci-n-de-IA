rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Bloqueo total por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // Reglas para Reportes Sentinel (Privacidad Diferencial)
    match /reports/{reportId} {
      allow create: if request.auth != null;
      // Solo permite leer si el reporte tiene ubicación pública fuzzeada
      allow get, list: if request.auth != null && resource.data.location_public != null;
    }

    // Reglas para Usuarios (Karma y Coins)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- NUEVO: Reglas para Sistema Fluvial ---

    // Colección river_status (El Semáforo - Estado Actual Ligero)
    match /river_status/{tramoId} {
      // Todos pueden ver el estado del río en el mapa
      allow read: if true;
      
      // Solo Guías pueden actualizar el semáforo mediante Batch Write.
      // Previene "Race Conditions" offline: Solo se acepta si el nuevo reporte es más reciente que el actual.
      allow write: if request.auth != null && 
                   request.auth.token.role == 'guia' &&
                   (
                     !exists(/databases/$(database)/documents/river_status/$(tramoId)) || 
                     request.resource.data.ultimo_reporte_ts >= resource.data.ultimo_reporte_ts
                   );
    }

    // Colección river_reports (Historial inmutable de reportes)
    match /river_reports/{reportId} {
      // Historial público para consulta
      allow read: if true;
      
      // Solo Guías pueden crear reportes nuevos y EL PAYLOAD DEBE SER ESTRICTO
      // Evita inyección de datos basura por scripts o manipulación de red
      allow create: if request.auth != null && 
                    request.auth.token.role == 'guia' &&
                    request.resource.data.keys().hasAll(['id_tramo', 'id_usuario', 'nivel_agua', 'estado_navegabilidad', 'fecha_reporte']) &&
                    request.resource.data.nivel_agua in ['Bajo', 'Normal', 'Alto', 'Peligroso'] &&
                    request.resource.data.estado_navegabilidad in ['Abierto', 'Precaución', 'Cerrado'] &&
                    request.resource.data.id_usuario == request.auth.uid;
      
      // Nadie puede modificar ni borrar el historial
      allow update, delete: if false;
    }
  }
}
