<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Territorio Jaguar" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Ruta Comunidad Shuar Yukutais</name>
    <desc>Visita guiada a la comunidad Shuar de Yukutais. Experiencia de turismo comunitario: artesanía, gastronomía tradicional y ceremonia de bienvenida. Nivel: Fácil — apto para todas las edades.</desc>
    <time>2026-01-22T09:00:00Z</time>
  </metadata>

  <wpt lat="-2.7340" lon="-78.0210">
    <name>Centro de Visitantes</name>
    <desc>Recepción del grupo. Compra de artesanías certificadas Jaguar Coin.</desc>
    <sym>Information</sym>
  </wpt>
  <wpt lat="-2.7410" lon="-78.0285">
    <name>Taller de Cerámica Shuar</name>
    <desc>Demostración de cerámica ancestral. Participa y lleva tu pieza. +50 puntos Jaguar Coin.</desc>
    <sym>Museum</sym>
  </wpt>
  <wpt lat="-2.7480" lon="-78.0340">
    <name>Maloca Ceremonial</name>
    <desc>Casa comunal. Presentación de danza tradicional y chicha de yuca.</desc>
    <sym>Building</sym>
  </wpt>
  <wpt lat="-2.7520" lon="-78.0390">
    <name>Huerto Medicinal</name>
    <desc>Jardín de plantas medicinales amazónicas. Guiado por curandero local.</desc>
    <sym>Forest</sym>
  </wpt>

