<gpx version="1.1" creator="Territorio Jaguar" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Mirador Volcán Sangay</name>
    <desc>Ascenso al mirador con vista directa al Sangay (5 286 msnm). Requiere guía local certificado y equipo de trekking. Parte del Parque Nacional Sangay - Patrimonio Natural UNESCO.</desc>
    <time>2026-02-10T05:30:00Z</time>
  </metadata>

  <wpt lat="-2.1950" lon="-78.1820">
    <name>Base Camp Sangay</name>
    <desc>Campamento base. Registro con Ministerio de Ambiente obligatorio.</desc>
    <sym>Campground</sym>
  </wpt>
  <wpt lat="-2.1700" lon="-78.2050">
    <name>Mirador Principal</name>
    <desc>Vista 360° del volcán Sangay activo. Altitud 3 840 msnm. No avanzar hacia el cráter.</desc>
    <sym>Summit</sym>
  </wpt>

