<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Territorio Jaguar" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Cascadas del Copal</name>
    <desc>Sendero ecoturístico hacia las cascadas del río Copal. Moderado, apto para familias con guía local. Área protegida Shuar.</desc>
    <time>2026-01-15T08:00:00Z</time>
  </metadata>

  <!-- Waypoints de interés -->
  <wpt lat="-2.5820" lon="-78.0640">
    <name>Inicio Sendero</name>
    <desc>Punto de partida. Registro obligatorio con guardaparques.</desc>
    <sym>Trailhead</sym>
  </wpt>
  <wpt lat="-2.5958" lon="-78.0812">
    <name>Cascada Menor</name>
    <desc>Primera cascada del recorrido. 12m de altura. Poza apta para nadar.</desc>
    <sym>Scenic Area</sym>
  </wpt>
  <wpt lat="-2.6105" lon="-78.0943">
    <name>Cascadas del Copal (Principal)</name>
    <desc>Cascada principal de 38m. Área sagrada Shuar. No cruzar la barrera.</desc>
    <sym>Waterfall</sym>
  </wpt>

  <!-- Track principal -->
  <trk>
    <name>Cascadas del Copal — Ruta Circular</name>
